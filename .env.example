# Backend Environment Variables
# Copy to .env for local development. In Coolify, set these as service env vars.

# --- Required ---
DATABASE_URL=postgres://courtcommand:courtcommand@localhost:5432/courtcommand?sslmode=disable
REDIS_URL=redis://localhost:6379/0

# --- Optional (with defaults) ---
PORT=8080
ENV=development
# ENV=production  # Set to "production" on Coolify

# Comma-separated list of allowed CORS origins
# Local dev:
CORS_ALLOWED_ORIGINS=http://localhost:5173
# Production (set in Coolify):
# CORS_ALLOWED_ORIGINS=https://courtcommand.app,https://news.courtcommand.app

# --- Coolify Production Values ---
# DATABASE_URL=postgres://USER:PASS@HOST:5432/courtcommand?sslmode=require
# REDIS_URL=redis://HOST:6379/0
# CORS_ALLOWED_ORIGINS=https://courtcommand.app,https://news.courtcommand.app
# ENV=production
