# Frontend Environment Variables (Vite)
# These are baked into the build at compile time (VITE_ prefix required).
# Copy to .env for local development. In Coolify, set these as build-time env vars.

# --- Required ---
VITE_API_URL=http://localhost:8080
# Production: VITE_API_URL=https://api.courtcommand.app

# --- Optional ---
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# --- Coolify Production Values ---
# VITE_API_URL=https://api.courtcommand.app
# VITE_GOOGLE_MAPS_API_KEY=your-production-key
